<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  macOS hardened-runtime entitlements.

  Why each entry:
    com.apple.security.cs.allow-jit             - V8 / Chromium needs JIT
    com.apple.security.cs.allow-unsigned-executable-memory - Electron/V8 requirement
    com.apple.security.files.user-selected.read-write - user picks their presentations folder
    com.apple.security.network.client           - downloading Google Fonts in decks
    com.apple.security.device.audio-input       - Reveal audio-recorder plugin (unused today, kept for headroom)
    com.apple.security.device.camera            - presenter webcam recording (future-proof)
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.device.audio-input</key>
    <true/>
    <key>com.apple.security.device.camera</key>
    <true/>
</dict>
</plist>
